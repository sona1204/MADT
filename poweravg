package com.example.poweravg;

import android.content.Intent;
import android.os.Bundle;
import android.view.View;
import android.widget.EditText;

import androidx.appcompat.app.AppCompatActivity;

public class MainActivity extends AppCompatActivity {

    EditText n1, n2;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        n1 = findViewById(R.id.n1);
        n2 = findViewById(R.id.n2);
    }

    public void power(View v) {
        double a = Double.parseDouble(n1.getText().toString());
        double b = Double.parseDouble(n2.getText().toString());

        double res = Math.pow(a, b);

        Intent i = new Intent(this, ResultActivity.class);
        i.putExtra("result", "Power = " + res);
        startActivity(i);
    }

    public void average(View v) {
        double a = Double.parseDouble(n1.getText().toString());
        double b = Double.parseDouble(n2.getText().toString());

        double res = (a + b) / 2;

        Intent i = new Intent(this, ResultActivity.class);
        i.putExtra("result", "Average = " + res);
        startActivity(i);
    }
}


